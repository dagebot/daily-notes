---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Calendar from '../components/Calendar.jsx';

const allPosts = (await getCollection('posts')).sort(
	(a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);

// 只显示最近7天的文章
const sevenDaysAgo = new Date();
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
sevenDaysAgo.setHours(0, 0, 0, 0);

const posts = allPosts.filter(post => new Date(post.data.date) >= sevenDaysAgo);
---

<Layout title="每日记录">
  <div class="wrapper">
    <aside class="sidebar-desktop">
      <Calendar posts={allPosts} client:load />
    </aside>
    
    <div class="main-container">
      <aside class="sidebar-mobile">
        <Calendar posts={allPosts} client:load />
      </aside>
      
      <section class="intro">
        <h1>📝 每日记录</h1>
        <p class="subtitle">记录日常的思考、感想与灵光一现</p>
      </section>

      <main class="content">
        <section class="posts">
          <h2 class="section-title">最近七天</h2>
          {posts.length > 0 ? (
            posts.map((post) => (
              <article class="post-card">
                <span class="date">{post.data.date.toISOString().split('T')[0]}</span>
                <h2>
                  <a href={`/posts/${post.slug}`}>{post.data.title}</a>
                </h2>
                <p>{post.data.excerpt}</p>
              </article>
            ))
          ) : (
            <p class="no-posts">最近七天没有日记记录</p>
          )}
        </section>
      </main>
    </div>
  </div>
</Layout>

<style>
  .wrapper {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  
  .main-container {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .sidebar-desktop {
    position: absolute;
    left: calc(50% + 400px + 2rem);
    top: 100px;
    width: 280px;
  }
  
  .sidebar-mobile {
    display: none;
    margin-bottom: 2rem;
    max-width: 320px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .intro {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  
  .intro h1 {
    font-family: var(--font-hand);
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }
  
  .subtitle {
    color: var(--color-muted);
    font-size: 1rem;
  }
  
  .content {
    min-width: 0;
  }
  
  .post-card {
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    background: white;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  
  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }
  
  .date {
    font-size: 0.8rem;
    color: var(--color-muted);
    font-family: var(--font-hand);
  }
  
  .post-card h2 {
    margin: 0.5rem 0 0.75rem;
    font-size: 1.3rem;
  }
  
  .post-card h2 a {
    text-decoration: none;
    color: var(--color-text);
  }
  
  .post-card h2 a:hover {
    color: var(--color-accent);
  }
  
  .post-card p {
    color: var(--color-muted);
    line-height: 1.7;
    font-size: 0.95rem;
  }
  
  .section-title {
    font-family: var(--font-hand);
    font-size: 1.5rem;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  .no-posts {
    color: var(--color-muted);
    font-style: italic;
    padding: 2rem;
    text-align: center;
    background: white;
    border-radius: 8px;
  }
  
  @media (max-width: 1200px) {
    .sidebar-desktop {
      display: none;
    }
    
    .sidebar-mobile {
      display: block;
    }
  }
</style>