---
interface Props {
  posts: { slug: string; data: { date: Date } }[];
}

const { posts } = Astro.props;

// Get all dates with posts (convert to YYYY-MM-DD string)
const postDates = new Set(posts.map(p => {
  const d = p.data.date;
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
}));

// Get current month from URL query or default to current month
const now = new Date();
const year = now.getFullYear();
const month = now.getMonth();

const monthName = `${year}-${String(month + 1).padStart(2, '0')}`;

// Get posts for current month to display in mini list
const currentMonthPosts = posts.filter(p => {
  const d = p.data.date;
  return d.getFullYear() === year && d.getMonth() === month;
}).slice(0, 5);
---

<div class="calendar">
  <div class="calendar-header">
    <a href="/archive" class="month-link">{monthName} →</a>
  </div>
  
  {currentMonthPosts.length > 0 && (
    <div class="recent-posts">
      {currentMonthPosts.map(post => (
        <a href={`/posts/${post.slug}`} class="recent-post">
          <span class="recent-date">{post.data.date.toISOString().split('T')[0].slice(5)}</span>
          <span class="recent-title">{post.data.title}</span>
        </a>
      ))}
    </div>
  )}
</div>

<style>
  .calendar {
    background: white;
    border-radius: 8px;
    padding: 1rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  
  .calendar-header {
    text-align: center;
    margin-bottom: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  .month-link {
    font-family: var(--font-hand);
    font-size: 1.1rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  
  .month-link:hover {
    opacity: 0.8;
  }
  
  .recent-posts {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .recent-post {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;
    border-radius: 4px;
    text-decoration: none;
    color: var(--color-text);
    transition: background 0.2s;
    font-size: 0.85rem;
  }
  
  .recent-post:hover {
    background: #f5e6d3;
  }
  
  .recent-date {
    color: var(--color-muted);
    font-size: 0.75rem;
    white-space: nowrap;
    font-family: var(--font-hand);
  }
  
  .recent-title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
