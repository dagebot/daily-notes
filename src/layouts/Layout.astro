---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo">📝 日记</a>
        <a href="/about">关于</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>© 2026 每日记录 · 用心记录每一天</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #faf8f5;
    --color-text: #3d3d3d;
    --color-accent: #8b4513;
    --color-muted: #6b6b6b;
    --color-border: #e8e4df;
    --font-serif: 'Noto Serif SC', 'Songti SC', serif;
    --font-hand: 'ZCOOL XiaoWei', cursive;
  }
  
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  
  html {
    font-family: var(--font-serif);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.8;
  }
  
  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  
  header {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  nav {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .logo {
    font-family: var(--font-hand);
    font-size: 1.5rem;
    color: var(--color-accent);
    text-decoration: none;
  }
  
  nav a:not(.logo) {
    color: var(--color-muted);
    text-decoration: none;
    margin-left: 1.5rem;
    transition: color 0.2s;
  }
  
  nav a:not(.logo):hover {
    color: var(--color-accent);
  }
  
  main {
    flex: 1;
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
    padding: 3rem 2rem;
  }
  
  footer {
    text-align: center;
    padding: 2rem;
    color: var(--color-muted);
    font-size: 0.875rem;
    border-top: 1px solid var(--color-border);
  }
  
  h1, h2, h3 {
    color: var(--color-accent);
    font-weight: 600;
  }
  
  a {
    color: var(--color-accent);
  }
  
  /* Calendar Styles */
  .calendar-container {
    background: white;
    border-radius: 12px;
    padding: 1rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    font-family: var(--font-serif);
  }
  
  .calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  .month-title {
    font-family: var(--font-hand);
    font-size: 1.1rem;
    color: var(--color-accent);
    font-weight: 600;
  }
  
  .nav-btn {
    background: none;
    border: none;
    font-size: 1.2rem;
    color: var(--color-muted);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: all 0.2s;
    line-height: 1;
  }
  
  .nav-btn:hover {
    background: var(--color-bg);
    color: var(--color-accent);
  }
  
  .calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
    margin-bottom: 4px;
  }
  
  .calendar-weekdays span {
    text-align: center;
    font-size: 0.7rem;
    color: var(--color-muted);
    padding: 0.25rem 0;
  }
  
  .calendar-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }
  
  .calendar-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    text-decoration: none;
    color: var(--color-text);
    border-radius: 6px;
    transition: all 0.2s;
    cursor: default;
  }
  
  .calendar-day:hover:not(.empty) {
    background: #f5e6d3;
  }
  
  .calendar-day.has-post {
    background: #f5e6d3;
    color: var(--color-accent);
    font-weight: 600;
    cursor: pointer;
  }
  
  .calendar-day.has-post:hover {
    background: var(--color-accent);
    color: white;
  }
  
  .calendar-day.today {
    border: 2px solid var(--color-accent);
  }
  
  .calendar-day.empty {
    pointer-events: none;
  }
  
  .calendar-footer {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }
  
  .today-btn {
    background: none;
    border: none;
    font-size: 0.8rem;
    color: var(--color-muted);
    cursor: pointer;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    transition: all 0.2s;
    font-family: var(--font-serif);
  }
  
  .today-btn:hover {
    background: var(--color-bg);
    color: var(--color-accent);
  }
</style>