---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
}

const { 
  title, 
  description = "把日常里的判断、感想与片刻灵感，整理成持续可回看的文字轨迹。",
  image = "/og-image.png",
  type = "website"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://notes.bub.build");
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site || "https://notes.bub.build")} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content="每日记录" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site || "https://notes.bub.build")} />
    
    <!-- General Meta -->
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo">Bub's Daily Notes</a>
        <div class="nav-links">
          <a href="/">首页</a>
          <a href="/about">关于</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>© 2026 Bub · 用心记录每一天</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #f5f1ea;
    --color-surface: rgba(255, 252, 247, 0.8);
    --color-panel: #fffdf9;
    --color-text: #241f1a;
    --color-accent: #8f3d22;
    --color-accent-strong: #6d2b16;
    --color-muted: #6d655d;
    --color-border: rgba(109, 82, 60, 0.14);
    --color-border-strong: rgba(109, 82, 60, 0.24);
    --shadow-soft: 0 24px 60px rgba(60, 34, 19, 0.08);
    --shadow-card: 0 16px 40px rgba(70, 40, 24, 0.08);
    --font-serif: 'Noto Serif SC', 'Songti SC', serif;
    --font-sans: 'Manrope', 'PingFang SC', 'Helvetica Neue', sans-serif;
  }
  
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  
  html {
    font-family: var(--font-serif);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.8;
  }
  
  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background:
      radial-gradient(circle at top left, rgba(201, 126, 79, 0.18), transparent 30%),
      radial-gradient(circle at top right, rgba(152, 177, 179, 0.14), transparent 26%),
      linear-gradient(180deg, #fcf8f1 0%, #f4eee7 55%, #f8f4ee 100%);
  }
  
  header {
    padding: 1.5rem 2rem 0;
  }
  
  nav {
    max-width: 1120px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: rgba(255, 250, 244, 0.72);
    backdrop-filter: blur(14px);
    box-shadow: 0 12px 30px rgba(78, 48, 27, 0.06);
  }
  
  .logo {
    font-family: var(--font-sans);
    font-size: 1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 800;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  
  nav a:not(.logo) {
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s, background-color 0.2s, border-color 0.2s;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    border: 1px solid transparent;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 600;
  }
  
  nav a:not(.logo):hover {
    color: var(--color-accent);
    background: rgba(143, 61, 34, 0.08);
    border-color: rgba(143, 61, 34, 0.12);
  }
  
  main {
    flex: 1;
    width: 100%;
    padding: 3rem 2rem 4rem;
  }
  
  footer {
    text-align: center;
    padding: 2rem;
    color: var(--color-muted);
    font-size: 0.875rem;
    border-top: 1px solid var(--color-border);
  }
  
  h1, h2, h3 {
    color: var(--color-accent);
    font-weight: 600;
  }
  
  a {
    color: var(--color-accent);
  }

  a, button {
    -webkit-tap-highlight-color: transparent;
  }

  a:focus-visible,
  button:focus-visible {
    outline: 2px solid rgba(143, 61, 34, 0.7);
    outline-offset: 3px;
  }
  
  /* Calendar Styles */
  .calendar-container {
    background: linear-gradient(180deg, rgba(255, 253, 249, 0.95), rgba(250, 244, 235, 0.92));
    border-radius: 24px;
    padding: 1.1rem;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-border);
    font-family: var(--font-serif);
    backdrop-filter: blur(12px);
  }
  
  .calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.85rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  .month-title {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 800;
  }
  
  .nav-btn {
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid var(--color-border);
    min-width: 2.5rem;
    min-height: 2.5rem;
    font-size: 1.1rem;
    color: var(--color-muted);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 999px;
    transition: all 0.2s;
    line-height: 1;
  }
  
  .nav-btn:hover {
    background: rgba(143, 61, 34, 0.08);
    color: var(--color-accent);
    border-color: rgba(143, 61, 34, 0.2);
  }

  .nav-btn-placeholder {
    visibility: hidden;
    pointer-events: none;
  }
  
  .calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
    margin-bottom: 4px;
  }
  
  .calendar-weekdays span {
    text-align: center;
    font-size: 0.72rem;
    font-family: var(--font-sans);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    padding: 0.35rem 0;
  }
  
  .calendar-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 0.3rem;
  }
  
  .calendar-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    text-decoration: none;
    color: var(--color-text);
    border-radius: 14px;
    transition: all 0.2s;
    cursor: default;
    border: 1px solid transparent;
  }
  
  .calendar-day:hover:not(.empty) {
    background: rgba(143, 61, 34, 0.08);
  }
  
  .calendar-day.has-post {
    background: linear-gradient(180deg, rgba(247, 227, 210, 0.95), rgba(243, 217, 196, 0.95));
    color: var(--color-accent);
    font-weight: 600;
    cursor: pointer;
    border-color: rgba(143, 61, 34, 0.12);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.45);
  }
  
  .calendar-day.has-post:hover {
    background: var(--color-accent);
    color: white;
  }
  
  .calendar-day.today {
    border-color: var(--color-accent);
  }
  
  .calendar-day.empty {
    pointer-events: none;
  }
  
  .calendar-footer {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }
  
  .today-btn {
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid var(--color-border);
    font-size: 0.8rem;
    color: var(--color-muted);
    cursor: pointer;
    padding: 0.55rem 0.95rem;
    border-radius: 999px;
    transition: all 0.2s;
    font-family: var(--font-sans);
    font-weight: 700;
  }
  
  .today-btn:hover {
    background: rgba(143, 61, 34, 0.08);
    color: var(--color-accent);
    border-color: rgba(143, 61, 34, 0.16);
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
      scroll-behavior: auto !important;
    }
  }

  @media (max-width: 720px) {
    header {
      padding: 1rem 1rem 0;
    }

    nav {
      border-radius: 24px;
      padding: 0.85rem 1rem;
    }

    .logo {
      font-size: 0.92rem;
      letter-spacing: 0.08em;
    }

    .nav-links {
      gap: 0.4rem;
    }

    nav a:not(.logo) {
      padding: 0.5rem 0.75rem;
      font-size: 0.88rem;
    }

    main {
      padding: 2rem 1rem 3rem;
    }
  }
</style>